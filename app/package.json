{
  "name": "baby-co-work",
  "private": true,
  "version": "0.1.0",
  "description": "新生儿家庭协作台 - Hackathon MVP",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"vite\" \"tsx watch server/index.ts\"",
    "dev:web": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "test": "vitest",
    "test:e2e": "playwright test",
    "smoke:ark": "tsx scripts/smoke-ark.ts"
  },
  "dependencies": {
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.1",
    "@vitejs/plugin-react": "4.5",
    "concurrently": "^9.2.4",
    "jsdom": "^26.1.0",
    "playwright": "^1.61.1",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  }
}
